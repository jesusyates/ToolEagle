# Supabase (required for Phase 17 - Account System)
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For db:migrate / db:migrate:one - get from Supabase Dashboard → Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Single file: npm run db:migrate:one -- 0032_v100_3_user_feedback.sql

# For public submit API (bypasses RLS when set)
# V100.1 supporter ledger (/api/donation/*) needs this in production for inserts
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Search Console & Indexing API (optional) - for /admin/indexing
# GSC_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GSC_SITE_URL=https://www.tooleagle.com/

# Plausible Analytics (optional) - for SEO page views, tool usage, conversion
# Add your domain from https://plausible.io (e.g. tooleagle.com)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=tooleagle.com

# Baidu Site Verification - 百度站长验证，用于提升收录
# 获取：https://ziyuan.baidu.com/ 添加站点后选择「HTML标签验证」，复制 code 值
# BAIDU_SITE_VERIFICATION=your-baidu-verification-code

# Baidu API 提交 - 用于 npm run baidu:submit 主动推送 sitemap
# 获取：百度站长平台 → 普通收录 → API 提交 → 复制 token
# BAIDU_TOKEN=your-baidu-api-token

# Contact email for privacy/terms pages - use your real email (Gmail, QQ, etc.)
# CONTACT_EMAIL=your-email@gmail.com

# ========== v27+ 功能所需 ==========

# OpenAI API Key - 用于 AI 生成、自动内容生成、Prompt 优化等
# 获取：https://platform.openai.com/api-keys 注册/登录后创建 API Key
# OPENAI_API_KEY=sk-...

# OpenAI 代理 Base URL（可选）- 国内或无法直连时使用代理
# 示例：OPENAI_BASE_URL=https://your-proxy.com/v1
# 不配置则默认 https://api.openai.com/v1
# OPENAI_BASE_URL=https://your-proxy-url/v1

# 系统代理（可选）- Node 脚本可能不继承系统代理，VPN 用户若 fetch failed 可尝试
# Clash 默认：HTTPS_PROXY=http://127.0.0.1:7890
# V2Ray 等：HTTPS_PROXY=http://127.0.0.1:端口
# HTTPS_PROXY=http://127.0.0.1:7890

# Upstash Redis - 用于缓存（搜索、trending 等），10 分钟 TTL 减少数据库压力
# 获取：https://upstash.com/ 注册后创建 Redis 数据库，在 Dashboard 的 REST API 中复制
# 不配置则缓存功能禁用，不影响其他功能
# UPSTASH_REDIS_REST_URL=https://xxx-xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Vercel Cron 密钥 - 保护 /api/generate-examples 每日自动生成 50 条示例
# 获取：自己生成一个随机字符串（如 openssl rand -hex 32）
# 部署到 Vercel 后，在 Project → Settings → Environment Variables 中配置
# 同时需在 vercel.json 中配置 cron 定时任务
# CRON_SECRET=your-random-secret-string

# V64 Affiliate Tools - URLs for tool recommendation blocks on zh pages
# AFFILIATE_TOOL_1=https://...
# AFFILIATE_TOOL_2=https://...
# AFFILIATE_TOOL_3=https://...

# V65 Email Auto Response - Resend (https://resend.com)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=hello@yourdomain.com

# ========== V94 Monetization ==========
# Lemon Squeezy (or any checkout) — ToolEagle Pro ~$9/mo. Used by all upgrade CTAs.
# NEXT_PUBLIC_PAYMENT_LINK=https://your-store.lemonsqueezy.com/checkout/buy/...

# Optional: donation QR images (WeChat / Alipay), public URL or /file.png in public/
# NEXT_PUBLIC_DONATE_WECHAT_QR=/donate-wechat.png
# NEXT_PUBLIC_DONATE_ALIPAY_QR=/donate-alipay.png

# ========== V98 Regional AI router ==========
# Global (primary) — optional model override (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# CN extension — set to 1/true to try regional provider before falling back to OpenAI
# ENABLE_CN_PROVIDER=0
# CN_PROVIDER=deepseek
# DeepSeek (OpenAI-compatible API) — https://api-docs.deepseek.com/
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# Qwen scaffold: wire in code first, then DASHSCOPE_API_KEY / QWEN_MODEL

# ========== V99 China delivery / AI stability ==========
# Chat completion timeout for OpenAI + DeepSeek (ms, min 5000). Prevents hung requests in CN/global.
# AI_CHAT_TIMEOUT_MS=55000

# ========== V100.3 Feedback (internal list/summary) ==========
# Random secret; send as header: x-feedback-admin-secret
# FEEDBACK_ADMIN_SECRET=your-random-secret

# ========== V100.4 CN human support (optional; UI hides missing) ==========
# Enterprise WeChat: full URL to open chat, OR path under /public e.g. /support-ent-wechat.png
# NEXT_PUBLIC_SUPPORT_ENTERPRISE_WECHAT_QR=
# NEXT_PUBLIC_SUPPORT_WECHAT_QR=
# NEXT_PUBLIC_SUPPORT_QQ_LINK=
# NEXT_PUBLIC_SUPPORT_QQ_LABEL=QQ

# ========== V101 CN aggregator Pro (order + callback) ==========
# Server-side: payment create + webhook verification. Requires SUPABASE_SERVICE_ROLE_KEY + migration 0033.
# AGGREGATOR_BASE_URL=https://your-aggregator.example.com
# AGGREGATOR_API_KEY=...
# Public URL the provider POSTs to (usually https://yourdomain.com/api/payment/callback)
# AGGREGATOR_NOTIFY_URL=https://www.tooleagle.com/api/payment/callback
# Optional path on BASE_URL (default /pay/create)
# AGGREGATOR_CREATE_PATH=/pay/create
# HMAC-SHA256 hex of raw callback body; sent in header x-aggregator-signature
# AGGREGATOR_WEBHOOK_SECRET=...
# Dev only: accept callbacks without signature when secret unset
# AGGREGATOR_ALLOW_UNSIGNED_CALLBACK=0
# CNY price for Pro monthly (display + order amount)
# V104.2 — 中文站 Pro 月费（默认 ¥29 为推荐档位；可按运营调整）
# CN_PRO_MONTHLY_CNY=29
# NEXT_PUBLIC_CN_PRO_MONTHLY_CNY=29
# Subscription length after each successful payment (days)
# PRO_SUBSCRIPTION_DAYS=30

# V101.1: run migration 0034_v101_1_orders_order_type.sql (orders.order_type pro|donation)

# ========== Ops — revenue dashboard & /api/revenue/* ==========
# Comma-separated Supabase auth user UUIDs and/or emails. Without these, /dashboard/revenue is hidden and 403 for APIs.
# OPERATOR_USER_IDS=
# OPERATOR_EMAILS=you@example.com
# Optional (development only): any logged-in user counts as operator — do not use in production.
# OPERATOR_DEV_ALLOW_ALL=true
