# Supabase (required for Phase 17 - Account System)
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For db:migrate - get from Supabase Dashboard → Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# For public submit API (bypasses RLS when set)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Search Console & Indexing API (optional) - for /admin/indexing
# GSC_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GSC_SITE_URL=https://www.tooleagle.com/

# Plausible Analytics (optional) - for SEO page views, tool usage, conversion
# Add your domain from https://plausible.io (e.g. tooleagle.com)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=tooleagle.com

# ========== v27+ 功能所需 ==========

# OpenAI API Key - 用于 AI 生成、自动内容生成、Prompt 优化等
# 获取：https://platform.openai.com/api-keys 注册/登录后创建 API Key
# OPENAI_API_KEY=sk-...

# OpenAI 代理 Base URL（可选）- 国内或无法直连时使用代理
# 示例：OPENAI_BASE_URL=https://your-proxy.com/v1
# 不配置则默认 https://api.openai.com/v1
# OPENAI_BASE_URL=https://your-proxy-url/v1

# 系统代理（可选）- Node 脚本可能不继承系统代理，VPN 用户若 fetch failed 可尝试
# Clash 默认：HTTPS_PROXY=http://127.0.0.1:7890
# V2Ray 等：HTTPS_PROXY=http://127.0.0.1:端口
# HTTPS_PROXY=http://127.0.0.1:7890

# Upstash Redis - 用于缓存（搜索、trending 等），10 分钟 TTL 减少数据库压力
# 获取：https://upstash.com/ 注册后创建 Redis 数据库，在 Dashboard 的 REST API 中复制
# 不配置则缓存功能禁用，不影响其他功能
# UPSTASH_REDIS_REST_URL=https://xxx-xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Vercel Cron 密钥 - 保护 /api/generate-examples 每日自动生成 50 条示例
# 获取：自己生成一个随机字符串（如 openssl rand -hex 32）
# 部署到 Vercel 后，在 Project → Settings → Environment Variables 中配置
# 同时需在 vercel.json 中配置 cron 定时任务
# CRON_SECRET=your-random-secret-string

# V64 Affiliate Tools - URLs for tool recommendation blocks on zh pages
# AFFILIATE_TOOL_1=https://...
# AFFILIATE_TOOL_2=https://...
# AFFILIATE_TOOL_3=https://...

# V65 Email Auto Response - Resend (https://resend.com)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=hello@yourdomain.com
