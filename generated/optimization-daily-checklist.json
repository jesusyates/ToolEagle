{
  "updatedAt": "2026-03-26T00:00:00.000Z",
  "dailyCommand": "node scripts/run-optimization-bootstrap-check.js",
  "notReadyMeans": [
    "real page-level GSC data has not arrived yet",
    "candidates/recommendations are still below bootstrap threshold",
    "scheduler remains paused (PAUSE_NO_DATA or PAUSE_CONTINUITY)"
  ],
  "readyMeans": [
    "optimization-readiness.ready === true",
    "optimization-bootstrap-status.launchRecommended === true",
    "optimization-scheduler-status.nextAction === ALLOW_FIRST_REAL_BATCH"
  ],
  "whenReadyRun": "npm run seo:opt:apply -- --write --limit 5",
  "firstBatchReminder": {
    "limit": 5,
    "bucketFocus": "high_potential only",
    "fieldScope": "description only",
    "titleChanges": "disabled",
    "introPrefixExpansion": "disabled by default"
  }
}
