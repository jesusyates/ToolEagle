{
  "version": 1,
  "description": "Maps behavioral signals to recommended short-form content archetypes. Scores are additive; top types win.",
  "content_types": [
    {
      "id": "tutorial",
      "label": "Tutorial / how-to",
      "weights": {
        "intent_tutorial": 4,
        "dominant_educational": 3,
        "tool_caption_usage": 2,
        "stage_lte_3": 2
      }
    },
    {
      "id": "storytelling",
      "label": "Storytelling",
      "weights": {
        "intent_story": 5,
        "dominant_storytelling": 4,
        "primary_followers": 1
      }
    },
    {
      "id": "selling",
      "label": "Offer / selling",
      "weights": {
        "intent_sales": 5,
        "dominant_selling": 4,
        "readiness_high": 2,
        "band_active_advanced": 2
      }
    },
    {
      "id": "opinion",
      "label": "Opinion / hot take",
      "weights": {
        "intent_views_viral": 3,
        "title_heavy": 2,
        "hook_heavy": 2
      }
    },
    {
      "id": "personal_brand",
      "label": "Personal brand / day-in-life",
      "weights": {
        "repeat_days_gte_4": 3,
        "niche_hints_gte_5": 3,
        "stage_gte_3": 2
      }
    },
    {
      "id": "list_tips",
      "label": "List / tips carousel",
      "weights": {
        "hashtag_heavy": 3,
        "primary_views": 2,
        "workflow_mid": 2
      }
    },
    {
      "id": "before_after",
      "label": "Before / after transformation",
      "weights": {
        "intent_promote_product": 4,
        "commerce_creator": 3,
        "readiness_medium_plus": 2
      }
    }
  ],
  "stage_aware_rules": [
    {
      "bands": ["beginner", "rising"],
      "boost_types": ["tutorial", "list_tips", "storytelling"],
      "penalize_types": ["selling"],
      "penalty": 3
    },
    {
      "bands": ["active", "advanced"],
      "boost_types": ["selling", "before_after", "opinion"],
      "penalize_types": [],
      "penalty": 0
    }
  ]
}
