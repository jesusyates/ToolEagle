{
  "version": 1,
  "description": "V190 — Monetization profile inference from V187 memory + V189 score + V187 profile. No vanity labels; thresholds are conservative.",
  "creator_types": [
    {
      "id": "hobbyist_explorer",
      "label": "Explorer / hobbyist",
      "signals": ["generation_count_lt_6", "tool_diversity_lte_2", "no_publish_redirect"]
    },
    {
      "id": "growth_focused_creator",
      "label": "Growth-focused creator",
      "signals": ["primary_goal_followers_or_views", "title_or_hashtag_heavy_usage", "workflow_completion_gte_35"]
    },
    {
      "id": "commerce_creator",
      "label": "Commerce-oriented creator",
      "signals": ["sales_intent_or_niche_shop", "dominant_style_selling", "copy_caption_or_hook_for_offer"]
    },
    {
      "id": "personal_brand_builder",
      "label": "Personal brand builder",
      "signals": ["story_intent", "repeat_usage_days_gte_3", "niche_hints_gte_4"]
    },
    {
      "id": "lead_gen_operator",
      "label": "Lead / B2C service creator",
      "signals": ["lead_keywords_in_niche", "caption_heavy", "balanced_tools"]
    }
  ],
  "monetization_modes": [
    {
      "id": "affiliate",
      "label": "Affiliate / discovery-first",
      "fits": ["followers_goal", "hashtag_title_bias", "low_hard_sell"]
    },
    {
      "id": "product_selling",
      "label": "Product selling",
      "fits": ["sales_intent", "commerce_creator", "readiness_gte_medium"]
    },
    {
      "id": "personal_brand",
      "label": "Personal brand",
      "fits": ["story_intent", "repeat_days", "consistent_niche"]
    },
    {
      "id": "lead_generation",
      "label": "Lead generation",
      "fits": ["lead_signals", "caption_pack_usage", "cta_copy_pattern"]
    },
    {
      "id": "ad_driven_growth",
      "label": "Ad-driven / scale growth",
      "fits": ["advanced_band_or_high_score", "high_gen_volume", "discovery_tools_mix"]
    }
  ],
  "readiness_rules": {
    "low": ["band_beginner_or_rising", "workflow_under_40", "generation_under_6"],
    "medium": ["band_active", "workflow_40_75", "or_publish_once"],
    "high": ["band_advanced", "or_sales_intent_with_publish", "workflow_over_70"]
  },
  "focus_rules": {
    "growth": ["beginner_or_rising_band", "or_readiness_low", "or_workflow_under_50"],
    "balanced": ["band_active", "readiness_medium"],
    "revenue": ["band_advanced", "or_readiness_high_with_sales_signals", "workflow_over_55"]
  },
  "revenue_guidance_layers": {
    "early_bands": ["beginner", "rising"],
    "early_message": "Prioritize audience and repeatable posting before pushing offers.",
    "late_bands": ["active", "advanced"],
    "late_message": "Test clear CTAs and proof — pair discovery (titles/hooks) with one conversion beat per post."
  },
  "copy_templates": {
    "goal_line": "Best-fit path right now: {mode} — your signals look like a {creator_type}.",
    "growth_vs_revenue": "Focus: {focus} ({focus_detail}).",
    "next_content": "Lean into {content_types} for the next posts — it matches your current pattern.",
    "recommended_action": "{action}"
  }
}
