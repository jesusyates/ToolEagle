        "required": [
          "topic",
          "platform",
          "options",
          "context"
        ],
        "optional": [
          "tone",
          "locale",
          "requestId"
        ],
        "nested": {
          "options": {
            "required": [
              "qualityTier",
              "maxVariants"
            ]
          },
          "context": {
            "required": [
              "callerType",
              "callerId"
            ]
          }
        }
      },
      "summary": "Generate a full TikTok post workflow package via chained agent capabilities.",
      "steps": [
        {
          "stepId": "caption_step",
          "capability": "generate_caption",
          "requestTemplate": {
            "input": {
              "topic": "{{input.topic}}",
              "platform": "tiktok",
              "tone": "{{input.tone}}",
              "locale": "{{input.locale}}"
            },
            "options": {
              "qualityTier": "{{input.options.qualityTier}}",
              "maxVariants": 1
            }
          }
        },
        {
          "stepId": "hashtags_step",
          "capability": "generate_hashtags",
          "requestTemplate": {
            "input": {
              "topic": "{{input.topic}}",
              "platform": "tiktok",
              "tone": "{{input.tone}}",
              "locale": "{{input.locale}}"
            },
            "options": {
              "qualityTier": "{{input.options.qualityTier}}",
              "maxVariants": 1
            }
          }
        },
        {
          "stepId": "tiktok_post_step",
          "capability": "generate_tiktok_post",
          "requestTemplate": {
            "input": {
              "topic": "{{steps.caption_step.output.caption}} {{steps.hashtags_step.output.hashtags}}",
              "platform": "tiktok",
              "tone": "{{input.tone}}",
              "locale": "{{input.locale}}"
            },
            "options": {
              "qualityTier": "{{input.options.qualityTier}}",
              "maxVariants": 1
            }
          }
        }
      ],
      "finalOutputTemplate": "{{steps.tiktok_post_step.output}}",
      "quote_endpoint": "/api/agent/v1/workflow/quote",
      "idempotency_supported": true
    },
